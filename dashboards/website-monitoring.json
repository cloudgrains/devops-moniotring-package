{
  "__inputs": [],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "table", "name": "Table", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "gauge", "name": "Gauge", "version": "" },
    { "type": "panel", "id": "state-timeline", "name": "State timeline", "version": "" }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true, "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Website and SSL Certificate Monitoring Dashboard — Monitoring Pack",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }, "id": 100, "title": "At a Glance", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }, "unit": "none" } },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 }, "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Total Monitored", "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(probe_success{job=~\"blackbox-http.*\"})", "instant": true, "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }, "unit": "none" } },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 }, "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Sites Up", "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(probe_success{job=~\"blackbox-http.*\"} == 1)", "instant": true, "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "mappings": [{ "options": { "0": { "color": "green", "index": 0, "text": "0" } }, "type": "value" }], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "unit": "none" } },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 }, "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Sites Down", "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count(probe_success{job=~\"blackbox-http.*\"} == 0) or vector(0)", "instant": true, "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "mappings": [{ "options": { "0": { "color": "green", "index": 0, "text": "0" } }, "type": "value" }], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 3 }] }, "unit": "none" } },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 }, "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "SSL Expiring <30d", "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "count((probe_ssl_earliest_cert_expiry{job=\"blackbox-ssl\"} - time()) / 86400 < 30) or vector(0)", "instant": true, "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 }] }, "unit": "s" } },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 }, "id": 5,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Avg Response Time", "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg(probe_duration_seconds{job=~\"blackbox-http.*\"})", "instant": true, "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 80 }, { "color": "green", "value": 99 }] }, "unit": "percent", "min": 0, "max": 100 } },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 }, "id": 6,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "center", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "24h Availability", "type": "stat",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "avg(avg_over_time(probe_success{job=~\"blackbox-http.*\"}[24h])) * 100", "instant": true, "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }, "id": 101, "title": "Status Timeline — Uptime History at a Glance", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed" },
          "custom": { "fillOpacity": 85, "lineWidth": 0, "spanNulls": false, "hideFrom": { "legend": false, "tooltip": false, "viz": false } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red", "index": 0 }, "1": { "text": "UP", "color": "green", "index": 1 } } }
          ]
        }
      },
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 6 }, "id": 7,
      "options": {
        "mergeValues": true, "showValue": "never", "alignValue": "center", "rowHeight": 0.85,
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "title": "Probe Status History", "type": "state-timeline",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_success{job=~\"blackbox-http.*\"}", "legendFormat": "{{instance}}", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 13 }, "id": 102, "title": "Website Status", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "cellOptions": { "type": "auto" }, "filterable": true },
          "mappings": [
            { "options": { "0": { "color": "red", "index": 0, "text": "DOWN" }, "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Status" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }, { "id": "custom.width", "value": 90 }] },
          { "matcher": { "id": "byName", "options": "Response Time" }, "properties": [{ "id": "unit", "value": "s" }, { "id": "decimals", "value": 3 }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 }] } }, { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }] },
          { "matcher": { "id": "byName", "options": "SSL Days" }, "properties": [{ "id": "unit", "value": "d" }, { "id": "decimals", "value": 0 }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "red", "value": 0 }, { "color": "orange", "value": 7 }, { "color": "yellow", "value": 30 }, { "color": "green", "value": 60 }] } }, { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }] },
          { "matcher": { "id": "byName", "options": "HTTP Status" }, "properties": [{ "id": "custom.width", "value": 100 }] },
          { "matcher": { "id": "byName", "options": "Target" }, "properties": [{ "id": "custom.width", "value": 300 }] },
          { "matcher": { "id": "byName", "options": "TLS Version" }, "properties": [{ "id": "custom.width", "value": 110 }] }
        ]
      },
      "gridPos": { "h": 11, "w": 24, "x": 0, "y": 14 }, "id": 8,
      "options": { "footer": { "show": false }, "showHeader": true, "sortBy": [{ "desc": false, "displayName": "Target" }] },
      "title": "All Targets — Current Status", "type": "table",
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "renameByName": { "instance": "Target", "Value #A": "Status", "Value #B": "Response Time", "Value #C": "HTTP Status", "Value #D": "SSL Days", "Value #E": "TLS Version" } } }
      ],
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_success{job=~\"blackbox-http.*\"}", "instant": true, "legendFormat": "{{instance}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_duration_seconds{job=~\"blackbox-http.*\"}", "instant": true, "legendFormat": "{{instance}}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_http_status_code{job=~\"blackbox-http.*\"}", "instant": true, "legendFormat": "{{instance}}", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox-ssl\"} - time()) / 86400", "instant": true, "legendFormat": "{{instance}}", "refId": "D" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_tls_version_info{job=~\"blackbox-http.*\"}", "instant": true, "legendFormat": "{{instance}} — {{version}}", "refId": "E" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 }, "id": 103, "title": "Response Times", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "gradientMode": "none", "lineInterpolation": "smooth", "lineWidth": 2, "pointSize": 5, "showPoints": "never", "spanNulls": false, "thresholdsStyle": { "mode": "line" } },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 5 }] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 9, "w": 14, "x": 0, "y": 26 }, "id": 9,
      "options": { "legend": { "calcs": ["lastNotNull", "max", "mean"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Response Time History", "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_duration_seconds{job=~\"blackbox-http.*\"}", "legendFormat": "{{instance}}", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "barAlignment": 0, "fillOpacity": 80, "gradientMode": "none", "lineWidth": 1, "pointSize": 5, "showPoints": "never", "spanNulls": false, "stacking": { "group": "A", "mode": "normal" }, "thresholdsStyle": { "mode": "off" } },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 9, "w": 10, "x": 14, "y": 26 }, "id": 10,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "none" } },
      "title": "HTTP Phase Breakdown (Stacked)", "type": "timeseries",
      "targets": [
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_http_duration_seconds{job=~\"blackbox-http.*\",phase=\"resolve\"}", "legendFormat": "DNS: {{instance}}", "refId": "A" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_http_duration_seconds{job=~\"blackbox-http.*\",phase=\"connect\"}", "legendFormat": "TCP: {{instance}}", "refId": "B" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_http_duration_seconds{job=~\"blackbox-http.*\",phase=\"tls\"}", "legendFormat": "TLS: {{instance}}", "refId": "C" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_http_duration_seconds{job=~\"blackbox-http.*\",phase=\"processing\"}", "legendFormat": "Server: {{instance}}", "refId": "D" },
        { "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_http_duration_seconds{job=~\"blackbox-http.*\",phase=\"transfer\"}", "legendFormat": "Transfer: {{instance}}", "refId": "E" }
      ]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 }, "id": 104, "title": "SSL Certificates", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "min": 0, "max": 365,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "red", "value": 0 }, { "color": "orange", "value": 7 }, { "color": "yellow", "value": 30 }, { "color": "green", "value": 60 }] },
          "unit": "d"
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 36 }, "id": 11,
      "options": { "minVizHeight": 75, "minVizWidth": 75, "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": true }, "showThresholdLabels": true, "showThresholdMarkers": true, "sizing": "auto" },
      "title": "SSL Certificate Expiry (Days Remaining)", "type": "gauge",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox-ssl\"} - time()) / 86400", "instant": true, "legendFormat": "{{instance}}", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "pointSize": 5, "showPoints": "never", "spanNulls": false, "thresholdsStyle": { "mode": "line+area" } },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 7 }, { "color": "yellow", "value": 30 }, { "color": "green", "value": 60 }] },
          "unit": "d"
        }
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 36 }, "id": 12,
      "options": { "legend": { "calcs": ["lastNotNull", "min"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "asc" } },
      "title": "SSL Expiry Trend", "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "(probe_ssl_earliest_cert_expiry{job=\"blackbox-ssl\"} - time()) / 86400", "legendFormat": "{{instance}}", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 46 }, "id": 105, "title": "TLS & DNS Information", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "cellOptions": { "type": "auto" }, "filterable": true },
          "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Target" }, "properties": [{ "id": "custom.width", "value": 300 }] },
          { "matcher": { "id": "byName", "options": "TLS Version" }, "properties": [{ "id": "custom.width", "value": 130 }, { "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "yellow", "value": null }] } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 47 }, "id": 13,
      "options": { "footer": { "show": false }, "showHeader": true },
      "title": "TLS Version by Target", "type": "table",
      "transformations": [
        { "id": "labelsToFields", "options": { "mode": "columns", "keepLabels": ["instance", "version"] } },
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true, "job": true }, "renameByName": { "instance": "Target", "version": "TLS Version" } } }
      ],
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_tls_version_info{job=~\"blackbox-http.*\"}", "instant": true, "legendFormat": "{{instance}}", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "smooth", "lineWidth": 2, "pointSize": 5, "showPoints": "never", "spanNulls": false, "thresholdsStyle": { "mode": "off" } },
          "mappings": [], "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }, "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 14, "x": 10, "y": 47 }, "id": 14,
      "options": { "legend": { "calcs": ["lastNotNull", "mean", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "DNS Resolution Time", "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_dns_lookup_time_seconds{job=~\"blackbox-http.*\"}", "legendFormat": "{{instance}}", "refId": "A" }]
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 55 }, "id": 106, "title": "Availability History", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 20, "gradientMode": "opacity", "lineInterpolation": "stepAfter", "lineWidth": 2, "pointSize": 5, "showPoints": "never", "spanNulls": false, "thresholdsStyle": { "mode": "off" } },
          "mappings": [{ "options": { "0": { "color": "red", "index": 0, "text": "DOWN" }, "1": { "color": "green", "index": 1, "text": "UP" } }, "type": "value" }],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "min": -0.1, "max": 1.1
        }
      },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 56 }, "id": 15,
      "options": { "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "right", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "title": "Probe Success History", "type": "timeseries",
      "targets": [{ "datasource": { "type": "prometheus", "uid": "prometheus" }, "expr": "probe_success{job=~\"blackbox-http.*\"}", "legendFormat": "{{instance}}", "refId": "A" }]
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "align": "left", "cellOptions": { "type": "auto" }, "filterable": true },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 90 }, { "color": "green", "value": 99 }] },
          "unit": "percent", "decimals": 2
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "1h %" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }] },
          { "matcher": { "id": "byName", "options": "6h %" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }] },
          { "matcher": { "id": "byName", "options": "24h %" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }] },
          { "matcher": { "id": "byName", "options": "7d %" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }] },
          { "matcher": { "id": "byName", "options": "30d %" }, "properties": [{ "id": "custom.cellOptions", "value": { "type": "color-background", "mode": "basic" } }] }
        ]
      },
